{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Usage Widget",
  "version": "0.1.0",
  "identifier": "com.claude.usagewidget",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Usage Widget",
        "width": 280,
        "height": 200,
        "minWidth": 240,
        "minHeight": 160,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "shadow": true,
        "dragDropEnabled": false,
        "backgroundColor": "#14161c",
        "x": null,
        "y": null
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["en-US"]
      }
    }
  }
}
